            "parameters": {
                "jsCode": "const body = $input.first().json.body;\n\nconst cliente = body.cliente_nome || 'Cliente';\nconst data = body.data || '';\nconst hora = body.hora || '';\nconst servico = body.servico || 'Serviço';\nconst profissional = body.profissional || '';\nconst telefone = body.telefone || '';\n\nconst msg = `Olá ${cliente}! 👋\n\nLembrando do seu agendamento:\n📅 *${data}* às *${hora}*\n✂️ Serviço: *${servico}*${profissional ? `\\n👤 Profissional: *${profissional}*` : ''}\n\nSalão Maicon Maksuel 💇‍♀️\n\nConfirme seu comparecimento respondendo *SIM* ou *NÃO*. 😊`;\n\nreturn [{\n  json: {\n    phone: telefone.replace(/\\D/g, ''),\n    message: msg,\n    agendamento_id: body.agendamento_id || null\n  }\n}];"
            },
